<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      spacing="16.0" style="-fx-padding: 20; -fx-background-color: #f1f5f9;">

    <Label text="Panel de Reportes"
           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>

    <HBox spacing="16">
        <VBox spacing="6" style="-fx-background-color: white; -fx-padding: 16; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-pref-width: 200;">
            <Label text="Ingresos" style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
            <Label fx:id="lblIngresos" text="0" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #16a34a;"/>
        </VBox>
        <VBox spacing="6" style="-fx-background-color: white; -fx-padding: 16; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-pref-width: 200;">
            <Label text="Atracciones" style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
            <Label fx:id="lblTotalAtracciones" text="0" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2563eb;"/>
        </VBox>
        <VBox spacing="6" style="-fx-background-color: white; -fx-padding: 16; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-pref-width: 200;">
            <Label text="Visitantes" style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
            <Label fx:id="lblTotalVisitantes" text="0" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #f59e0b;"/>
        </VBox>
        <VBox spacing="6" style="-fx-background-color: white; -fx-padding: 16; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-pref-width: 200;">
            <Label text="Alertas" style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
            <Label fx:id="lblAlertasActivas" text="0" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #dc2626;"/>
        </VBox>
    </HBox>

    <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 16; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8;">
        <Label text="Top Atracciones Mas Visitadas" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
        <ListView fx:id="listaTopAtracciones" prefHeight="150"/>
    </VBox>

    <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 16; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8;">
        <Label text="Tiempos Promedio de Espera" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
        <ListView fx:id="listaTiemposEspera" prefHeight="150"/>
    </VBox>

    <HBox spacing="10">
        <Button text="Refrescar Reportes" onAction="#refrescarReportes"
                style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-cursor: hand; -fx-padding: 10 20; -fx-background-radius: 6;"/>
        <Button text="Generar Reporte Diario" onAction="#generarReporte"
                style="-fx-background-color: #16a34a; -fx-text-fill: white; -fx-cursor: hand; -fx-padding: 10 20; -fx-background-radius: 6;"/>
    </HBox>

</VBox>