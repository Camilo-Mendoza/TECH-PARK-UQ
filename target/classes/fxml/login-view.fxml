<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      spacing="20.0" style="-fx-padding: 40; -fx-background-color: #f1f5f9;"
      alignment="CENTER" maxWidth="450" maxHeight="500">

    <!-- Título -->
    <VBox spacing="8" alignment="CENTER">
        <Label text="🎢 Tech-Park UQ" 
               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
        <Label text="Inicio de Sesión"
               style="-fx-font-size: 16px; -fx-text-fill: #64748b;"/>
    </VBox>

    <!-- Selector de rol -->
    <VBox spacing="8" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8;">
        <Label text="Tipo de usuario:" style="-fx-font-weight: bold; -fx-text-fill: #334155;"/>
        <HBox spacing="10" alignment="CENTER">
            <ToggleButton fx:id="btnVisitante" text="👤 Visitante" 
                          selected="true"
                          style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-padding: 10 20; -fx-background-radius: 6; -fx-cursor: hand;"/>
            <ToggleButton fx:id="btnOperador" text="🔧 Operador"
                          style="-fx-background-color: #94a3b8; -fx-text-fill: white; -fx-padding: 10 20; -fx-background-radius: 6; -fx-cursor: hand;"/>
            <ToggleButton fx:id="btnAdmin" text="⚙ Admin"
                          style="-fx-background-color: #94a3b8; -fx-text-fill: white; -fx-padding: 10 20; -fx-background-radius: 6; -fx-cursor: hand;"/>
        </HBox>

        <!-- Campos de login -->
        <VBox spacing="12" style="-fx-padding: 10 0 0 0;">
            <VBox spacing="4">
                <Label text="Correo electrónico:" style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
                <TextField fx:id="txtEmail" promptText="ejemplo@email.com"
                           style="-fx-padding: 10; -fx-background-radius: 6; -fx-border-color: #cbd5e1; -fx-border-radius: 6;"/>
            </VBox>
            <VBox spacing="4">
                <Label text="Contraseña:" style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
                <PasswordField fx:id="txtPassword" promptText="••••••••"
                               style="-fx-padding: 10; -fx-background-radius: 6; -fx-border-color: #cbd5e1; -fx-border-radius: 6;"/>
            </VBox>
        </VBox>

        <!-- Mensaje de error -->
        <Label fx:id="lblError" text="" 
               style="-fx-text-fill: #dc2626; -fx-font-size: 12px; -fx-padding: 4 0 0 0;"
               wrapText="true"/>

        <!-- Botón de login -->
        <Button text="Iniciar Sesión" onAction="#iniciarSesion"
                maxWidth="Infinity"
                style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 12; -fx-background-radius: 6; -fx-cursor: hand;"/>
    </VBox>

    <!-- Datos de prueba -->
    <VBox spacing="4" style="-fx-background-color: #fef3c7; -fx-padding: 12; -fx-background-radius: 8; -fx-border-color: #f59e0b; -fx-border-radius: 8;">
        <Label text=" Datos de prueba:" style="-fx-font-weight: bold; -fx-text-fill: #92400e; -fx-font-size: 12px;"/>
        <Label text="Visitante: carlos@email.com / 1234" style="-fx-text-fill: #78350f; -fx-font-size: 11px;"/>
        <Label text="Operador: juan@techpark.com / op123" style="-fx-text-fill: #78350f; -fx-font-size: 11px;"/>
        <Label text="Admin: admin@techpark.com / admin123" style="-fx-text-fill: #78350f; -fx-font-size: 11px;"/>
    </VBox>
</VBox>